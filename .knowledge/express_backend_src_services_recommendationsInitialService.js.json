{"is_source_file": true, "format": "JavaScript", "description": "This file defines a service module for generating initial role recommendations in a career navigation application. It includes functions for role normalization, deduplication, fallback padding with a predefined catalog, scoring based on protentional proficiency and compatibility (including 3/2 validation), and reranking mechanisms. The main exported function `generateInitialRecommendationsPersonaDrivenBedrockOnly` orchestrates these to produce a list of 1-5 tailored roles based on a final persona input, sourcing initial data from an external `bedrockService`.", "external_files": ["./bedrockService", "./scoringEngine"], "external_methods": ["bedrockService.getInitialRecommendations", "buildThreeTwoReport", "scoreRoleCompatibility"], "published": ["generateInitialRecommendationsPersonaDrivenBedrockOnly"], "classes": [], "methods": [{"name": "_clampPercent(n)", "description": "Clamps a number n to the 0..100 range, returning 0 if input is not finite.", "scope": "", "scopeKind": ""}, {"name": "_buildRingScores({ requiredSkillsCount, masteryAreas, growthAreas } = {})", "description": "Builds ring scores representing mastery and growth percentages based on required skills and areas.", "scope": "", "scopeKind": ""}, {"name": "_threeTwoValidationScore(threeTwoReport)", "description": "Returns 100 if the threeTwoReport status is 'validated', else 0.", "scope": "", "scopeKind": ""}, {"name": "_rerankByThreeTwoAndCompatibility(scoredRoles)", "description": "Sorts roles prioritizing fallback status, validation score, and compatibility score.", "scope": "", "scopeKind": ""}, {"name": "_extractPersonaSkillsWithProficiency(finalPersona)", "description": "Extracts and normalizes proficiency-bearing skills from a persona object.", "scope": "", "scopeKind": ""}, {"name": "_normalizeRoleForInitialRecommendations(role)", "description": "Normalizes a role object to include required skills and key responsibilities in a standard format.", "scope": "", "scopeKind": ""}, {"name": "_dedupeByRoleTitle(roles)", "description": "Removes duplicate roles based on normalized role title in a case-insensitive manner.", "scope": "", "scopeKind": ""}, {"name": "_markFallback(role, { reason })", "description": "Normalizes a role and marks it as fallback-filled with a reason.", "scope": "", "scopeKind": ""}, {"name": "_markNonFallback(role)", "description": "Normalizes a role and explicitly marks it as not fallback-filled.", "scope": "", "scopeKind": ""}, {"name": "_padToExactlyFiveRoles({ bedrockRoles, fallbackCatalog })", "description": "Pads a set of roles with fallback roles to ensure exactly five roles, maintaining deterministic order and avoiding duplicates.", "scope": "", "scopeKind": ""}, {"name": "_scoreRoles(finalPersona, roles)", "description": "Scores roles by comparing persona skills to required skills, with fallback scoring if proficiency data is absent.", "scope": "", "scopeKind": ""}, {"name": "generateInitialRecommendationsPersonaDrivenBedrockOnly({ finalPersona, personaId, options = {} } = {})", "description": "Main exported function that fetches initial role recommendations from Bedrock based on a persona, pads/fills to 5 roles, scores, reranks, and returns the final list along with metadata.", "scope": "", "scopeKind": ""}], "calls": ["bedrockService.getInitialRecommendations", "buildThreeTwoReport", "scoreRoleCompatibility"], "search-terms": ["recommendationsInitialService", "generateInitialRecommendations", "bedrockService", "scoringEngine", "initialRecommendations", "role normalization", "fallback catalog", "proficiency extraction"], "state": 2, "file_id": 89, "knowledge_revision": 279, "git_revision": "7183361ac27a80088495e759f5ef054d4fe3d7d0", "revision_history": [{"194": "214994a0bf50aa2a6798dba6c17c7a178dda43b1"}, {"218": "7183361ac27a80088495e759f5ef054d4fe3d7d0"}, {"279": "7183361ac27a80088495e759f5ef054d4fe3d7d0"}], "ctags": [{"_type": "tag", "name": "INITIAL_RECOMMENDATI