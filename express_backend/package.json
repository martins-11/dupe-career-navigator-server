{
  "name": "express_backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Express backend for professional persona builder (PostgreSQL/AWS RDS placeholders).",
  "main": "src/server.js",
  "scripts": {
    "prestart": "node scripts/free-port.js",
    "predev": "node scripts/free-port.js",
    "start": "node src/server.js",
    "dev": "node src/server.js",
    "db:migrate": "node src/db/migrate.js",
    "db:check": "node src/db/check.cjs",
    "db:verify": "node src/db/verifyTables.js",
    "validate:nonsense": "node scripts/validate-nonsense-input.js",
    "smoke:db": "node scripts/test-db.js",
    "smoke:bedrock": "node scripts/test-bedrock.js",
    "seed:roles": "node scripts/seed-roles.js",
    "verify:roles": "node scripts/verify-roles.js",
    "verify:roles-search": "node scripts/verify-roles-search.js",
    "verify:day2-integration": "node scripts/verify-day2-integration.js",
    "test": "NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --runInBand",
    "test:integration": "NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --runInBand --testPathPatterns=tests/integration"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.995.0",
    "ajv": "^8.18.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "mammoth": "^1.10.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "mysql2": "^3.17.3",
    "pdf-parse": "^1.1.1",
    "pg": "^8.12.0",
    "supertest": "^7.2.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "jest": "^30.2.0"
  }
}
